{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "RRIV: Build Datalogger Debug Binary",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "-p=app"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {
            "label": "RRIV: Build Probe Debug Binary",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "-p=app",
                "--no-default-features",
                "--features=storage-disabled"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
         {
            "label": "RRIV: Build Probe Release",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "-p=app",
                "--release",
                "--no-default-features",
                "--features=storage-disabled"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {
            "label": "RRIV: Build Datalogger Release Binary",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--release",
                "-p=app"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {
            "label": "RRIV: Clean",
            "type": "shell",
            "command": "cargo",
            "args": [
                "clean",
                "--release",
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {
            "label": "RRIV: Clean Debug",
            "type": "shell",
            "command": "cargo",
            "args": [
                "clean"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
        {
            "label": "RRIV: Build Datalogger Release",
            "dependsOn": [
                "RRIV: Clean",
                "RRIV: Build Datalogger Release Binary"
            ]
        },
        {
            "label": "RRIV: Build Board Crate",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "-p=rriv_board_0_4_2"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        },
    ]
}